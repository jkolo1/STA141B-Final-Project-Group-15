# group by city, extract year and month, and select the previous month
def feature_engineering(df):
    g = df.groupby("RegionName")["Value"]
    df["Year"] = df["Date"].dt.year
    df["Month"] = df["Date"].dt.month
    df["Lag1"] = g.shift(1)
    df["Lag12"] = g.shift(12)
    
    # then calculate how many percentages icnrease or decrease since last month or year
    df["MoM"] = (df["Value"] - df["Lag1"]) / df["Lag1"]
    df["YoY"] = (df["Value"] - df["Lag12"]) / df["Lag12"]
    df["MA3"] = g.transform(lambda x: x.rolling(3).mean())
    return df

